# env files — ห้าม commit เด็ดขาด มี DB password, JWT secret จริง
.env
.env.*
!.env.example

# dependencies
node_modules/

# build output
.next/
out/
build/
dist/

# frontend-dist is the built, deployable frontend bundle — must be tracked in full
!frontend-dist/
!frontend-dist/node_modules/
!frontend-dist/.next/

# uploads (ไฟล์ที่ user อัปโหลดจริง ไม่ใช่โค้ด)
backend/uploads/*
!backend/uploads/.gitkeep

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
*.pem
.vscode/
.idea/

# typescript
*.tsbuildinfo
next-env.d.ts
